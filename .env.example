N8N_ENCRYPTION_KEY=change-me-generate-32-plus-random-bytes
N8N_SETUP_EMAIL=owner@n8n.local
N8N_SETUP_PASSWORD=change-me
N8N_SETUP_FIRST_NAME=Owner
N8N_SETUP_LAST_NAME=User

N8N_PORT=5678
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678
GENERIC_TIMEZONE=UTC
N8N_LOG_LEVEL=info

DB_TYPE=sqlite
DB_SQLITE_DATABASE=/app/data/database.sqlite
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change-me-postgres
DB_POSTGRESDB_SSL_MODE=disable

N8N_CONCURRENCY_PRODUCTION_LIMIT=0
N8N_TURBO_CONCURRENCY_PER_WORKFLOW_LIMIT=0
N8N_TURBO_CONCURRENCY_QUEUE_SIZE=1000
N8N_TURBO_CONCURRENCY_ACQUIRE_TIMEOUT_SECONDS=300
N8N_TURBO_EXECUTION_DISPATCHER=local
N8N_TURBO_EXECUTION_REDIS_ADDR=
N8N_TURBO_EXECUTION_REDIS_PASSWORD=
N8N_TURBO_EXECUTION_REDIS_DB=0
N8N_TURBO_EXECUTION_NATS_URL=nats://127.0.0.1:4222
N8N_TURBO_EXECUTION_STREAM=n8n.executions
N8N_TURBO_EXECUTION_CONSUMER=n8n-turbo-worker
EXECUTIONS_TIMEOUT=-1
EXECUTIONS_TIMEOUT_MAX=3600
N8N_EXECUTIONS_DATA_SAVE_ON_ERROR=all
N8N_EXECUTIONS_DATA_SAVE_ON_SUCCESS=all
N8N_EXECUTIONS_DATA_SAVE_MANUAL_EXECUTIONS=true
N8N_EXECUTIONS_DATA_SAVE_ON_PROGRESS=false
N8N_TURBO_SCHEDULER_LEADER_ENABLED=false
N8N_TURBO_SCHEDULER_LEADER_REDIS_ADDR=
N8N_TURBO_SCHEDULER_LEADER_REDIS_PASSWORD=
N8N_TURBO_SCHEDULER_LEADER_REDIS_DB=0
N8N_TURBO_SCHEDULER_LEADER_KEY=n8n-turbo:scheduler:leader
N8N_TURBO_SCHEDULER_LEADER_TTL_SECONDS=30

N8N_TURBO_FRONTEND_DIR=/app/ui
UI_PATH=/app/ui
N8N_TURBO_BINARY_DATA_PATH=/app/storage/binary
N8N_DEFAULT_BINARY_DATA_MODE=filesystem
